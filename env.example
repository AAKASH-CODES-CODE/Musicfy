# Copy this file to .env and fill in your values
# Get these from https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Change this to your actual domain when deploying
# For local dev: http://localhost:5000/callback
# For Render: https://your-app-name.onrender.com/callback
REDIRECT_URI=http://localhost:5000/callback

# Generate a strong random secret key (e.g. run: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=replace-with-a-long-random-string
